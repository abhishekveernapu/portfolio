# ═══════════════════════════════════════════
#  Portfolio — Environment Variables (Example)
# ═══════════════════════════════════════════
# Copy this to .env and fill in your values.
# All VITE_ prefixed variables are exposed to the client.

# ─── Social Media Links ───
VITE_GITHUB_URL=https://github.com/your-username
VITE_LINKEDIN_URL=https://linkedin.com/in/your-username
VITE_TWITTER_URL=https://twitter.com/your-username
VITE_EMAIL=your@email.com

# ─── Resume (Google Drive shareable link or local path) ───
VITE_RESUME_URL=/resume.pdf

# ─── Contact / Profile Image (Google Drive shareable link or local path) ───
VITE_PROFILE_IMAGE=

# ─── Project Images (Google Drive shareable links or local paths) ───
VITE_PROJECT_IMAGE_CRYPTOSDEN=/projects/cryptosden.jpg
VITE_PROJECT_IMAGE_FARM_NIMBUS=/projects/farm-nimbus.jpg
VITE_PROJECT_IMAGE_AI_CHATBOT=/projects/ai-chatbot.jpg
VITE_PROJECT_IMAGE_NEWS_FEED=/projects/news-feed.jpg
